// Comissiona AI — Prisma Schema
// Multi-tenant SaaS para gestão de comissões comerciais
// Deploy: PostgreSQL (Supabase / Railway / Neon)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── TENANTS ─────────────────────────────────────────────────────────────────

model Tenant {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  document    String?  // CNPJ
  email       String
  phone       String?
  logoUrl     String?
  taxRate     Decimal  @default(0.00) @db.Decimal(5, 4) // alíquota padrão
  plan        String   @default("starter") // starter | pro | enterprise
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users            User[]
  products         Product[]
  commissionRules  CommissionRule[]
  sellers          Seller[]
  partners         Partner[]
  employees        Employee[]
  customers        Customer[]
  sales            Sale[]
  commissions      Commission[]
  paymentBatches   PaymentBatch[]
  goals            Goal[]
  campaigns        Campaign[]
  auditLogs        AuditLog[]

  @@index([slug])
  @@map("tenants")
}

// ─── USERS & AUTH ─────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id])
  name         String
  email        String
  passwordHash String
  role         UserRole  @default(SELLER)
  active       Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Link to specific person type (optional)
  sellerId     String?   @unique
  partnerId    String?   @unique
  employeeId   String?   @unique

  seller       Seller?   @relation(fields: [sellerId], references: [id])
  partner      Partner?  @relation(fields: [partnerId], references: [id])
  employee     Employee? @relation(fields: [employeeId], references: [id])

  auditLogs    AuditLog[]
  refreshTokens RefreshToken[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

enum UserRole {
  ADMIN
  SALES_MANAGER
  FINANCIAL
  SELLER
  PARTNER
  EMPLOYEE
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

// ─── PRODUCTS ─────────────────────────────────────────────────────────────────

model Product {
  id               String      @id @default(cuid())
  tenantId         String
  tenant           Tenant      @relation(fields: [tenantId], references: [id])
  name             String
  description      String?
  category         String?
  type             ProductType @default(MAIN)
  parentId         String?     // para módulos vinculados a produto principal
  parent           Product?    @relation("ProductModules", fields: [parentId], references: [id])
  modules          Product[]   @relation("ProductModules")
  color            String?     @default("#4f46e5")
  hasImplantation  Boolean     @default(false)
  hasMonthly       Boolean     @default(true)
  allowsUpsell     Boolean     @default(false)
  allowsCrossSell  Boolean     @default(false)
  generatesCommission Boolean  @default(true)
  active           Boolean     @default(true)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  commissionRules  CommissionRule[]
  saleItems        SaleItem[]

  @@index([tenantId])
  @@index([tenantId, active])
  @@map("products")
}

enum ProductType {
  MAIN
  MODULE
  ADDON
  SERVICE
  PARTNER_PRODUCT
}

// ─── COMMISSION RULES ─────────────────────────────────────────────────────────

model CommissionRule {
  id                         String          @id @default(cuid())
  tenantId                   String
  tenant                     Tenant          @relation(fields: [tenantId], references: [id])
  name                       String
  description                String?
  productId                  String?         // null = aplica a todos
  product                    Product?        @relation(fields: [productId], references: [id])
  productCategory            String?
  saleOrigin                 String?         // null = qualquer origem
  beneficiaryType            BeneficiaryType
  commissionType             CommissionType
  percentage                 Decimal?        @db.Decimal(8, 4)
  fixedAmount                Decimal?        @db.Decimal(12, 2)
  triggerEvent               TriggerEvent    @default(INVOICE_PAID)
  installmentNumber          Int?            // para 1ª, 3ª mensalidade
  appliesAfterDays           Int?            // prazo padrão p/ previsão
  appliesOnNetAmount         Boolean         @default(true) // sempre sobre líquido
  requiresCustomerActive     Boolean         @default(true)
  requiresInvoicePaid        Boolean         @default(true)
  requiresManagerApproval    Boolean         @default(false)
  active                     Boolean         @default(true)
  startDate                  DateTime?
  endDate                    DateTime?
  createdAt                  DateTime        @default(now())
  updatedAt                  DateTime        @updatedAt

  commissions                Commission[]

  @@index([tenantId])
  @@index([tenantId, productId])
  @@index([tenantId, active])
  @@map("commission_rules")
}

enum BeneficiaryType {
  SELLER
  PARTNER
  EMPLOYEE
}

enum CommissionType {
  PERCENTAGE_IMPLANTATION
  PERCENTAGE_MONTHLY
  FIXED_AMOUNT
  FIRST_MONTHLY_PAYMENT
  THIRD_MONTHLY_PAYMENT
  RECURRING
  BONUS
}

enum TriggerEvent {
  CONTRACT_SIGNED
  INVOICE_ISSUED
  INVOICE_PAID
  FIRST_INVOICE_PAID
  THIRD_INVOICE_PAID
  MANUAL_APPROVAL
}

// ─── PEOPLE ───────────────────────────────────────────────────────────────────

model Seller {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  email       String
  phone       String?
  role        String?
  team        String?
  managerId   String?
  manager     Seller?  @relation("SellerManager", fields: [managerId], references: [id])
  reports     Seller[] @relation("SellerManager")
  status      String   @default("active")
  joinDate    DateTime?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user         User?
  sales        Sale[]
  commissions  Commission[]
  goals        Goal[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("sellers")
}

model Partner {
  id                 String   @id @default(cuid())
  tenantId           String
  name               String
  type               String   @default("pf") // pf | pj
  document           String?
  email              String
  phone              String?
  pixKey             String?
  bankName           String?
  bankAgency         String?
  bankAccount        String?
  authorizedProducts String[] // array de product IDs
  status             String   @default("active")
  active             Boolean  @default(true)
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user         User?
  sales        Sale[]
  commissions  Commission[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("partners")
}

model Employee {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  email       String
  department  String?
  status      String   @default("active")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user         User?
  sales        Sale[]  @relation("EmployeeReferrals")
  commissions  Commission[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("employees")
}

// ─── CUSTOMERS ────────────────────────────────────────────────────────────────

model Customer {
  id               String   @id @default(cuid())
  tenantId         String
  tenant           Tenant   @relation(fields: [tenantId], references: [id])
  companyName      String
  tradeName        String?
  document         String?  // CNPJ/CPF
  segment          String?
  city             String?
  state            String?
  email            String?
  phone            String?
  status           String   @default("active")
  origin           String?
  sellerId         String?
  seller           Seller?  @relation(fields: [sellerId], references: [id])
  // nota: seller relation on Seller side already
  partnerId        String?
  partner          Partner? @relation(fields: [partnerId], references: [id])
  employeeId       String?
  employee         Employee? @relation(fields: [employeeId], references: [id])
  entryDate        DateTime?
  notes            String?
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  sales            Sale[]

  @@index([tenantId])
  @@index([tenantId, sellerId])
  @@map("customers")
}

// ─── SALES ────────────────────────────────────────────────────────────────────

model Sale {
  id                 String     @id @default(cuid())
  tenantId           String
  tenant             Tenant     @relation(fields: [tenantId], references: [id])
  customerId         String
  customer           Customer   @relation(fields: [customerId], references: [id])
  sellerId           String
  seller             Seller     @relation(fields: [sellerId], references: [id])
  partnerId          String?
  partner            Partner?   @relation(fields: [partnerId], references: [id])
  employeeId         String?    // colaborador indicador
  employee           Employee?  @relation("EmployeeReferrals", fields: [employeeId], references: [id])
  origin             String
  status             SaleStatus @default(PROPOSAL)
  taxRate            Decimal    @db.Decimal(5, 4) // ex: 0.10 = 10%
  saleDate           DateTime
  contractDate       DateTime?
  billingStartDate   DateTime?
  cancelledAt        DateTime?
  cancelReason       String?
  notes              String?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  items              SaleItem[]
  commissions        Commission[]
  invoices           Invoice[]

  @@index([tenantId])
  @@index([tenantId, sellerId])
  @@index([tenantId, status])
  @@index([tenantId, saleDate])
  @@map("sales")
}

enum SaleStatus {
  PROPOSAL
  CLOSED
  CONTRACT_SIGNED
  IN_IMPLEMENTATION
  ACTIVE
  CANCELLED
  DEFAULTING
  SUSPENDED
}

model SaleItem {
  id          String    @id @default(cuid())
  saleId      String
  sale        Sale      @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  type        ItemType  @default(MONTHLY)
  grossValue  Decimal   @db.Decimal(12, 2)
  netValue    Decimal   @db.Decimal(12, 2) // grossValue * (1 - taxRate)
  taxRate     Decimal   @db.Decimal(5, 4)
  quantity    Int       @default(1)
  notes       String?
  createdAt   DateTime  @default(now())

  commissions Commission[]

  @@index([saleId])
  @@index([productId])
  @@map("sale_items")
}

enum ItemType {
  IMPLANTATION
  MONTHLY
  ANNUAL
  ONE_TIME
}

// ─── INVOICES ─────────────────────────────────────────────────────────────────

model Invoice {
  id             String        @id @default(cuid())
  tenantId       String
  saleId         String
  sale           Sale          @relation(fields: [saleId], references: [id])
  installmentNum Int           // número da parcela/mensalidade
  dueDate        DateTime
  amount         Decimal       @db.Decimal(12, 2)
  status         InvoiceStatus @default(PENDING)
  paidAt         DateTime?
  paidAmount     Decimal?      @db.Decimal(12, 2)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([tenantId])
  @@index([saleId])
  @@index([tenantId, status])
  @@map("invoices")
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

// ─── COMMISSIONS ─────────────────────────────────────────────────────────────

model Commission {
  id                          String           @id @default(cuid())
  tenantId                    String
  tenant                      Tenant           @relation(fields: [tenantId], references: [id])
  saleId                      String
  sale                        Sale             @relation(fields: [saleId], references: [id])
  saleItemId                  String?
  saleItem                    SaleItem?        @relation(fields: [saleItemId], references: [id])
  ruleId                      String
  rule                        CommissionRule   @relation(fields: [ruleId], references: [id])
  beneficiaryType             BeneficiaryType
  beneficiaryId               String           // sellerId | partnerId | employeeId
  // Beneficiary denormalized for query speed
  sellerId                    String?
  seller                      Seller?          @relation(fields: [sellerId], references: [id])
  partnerId                   String?
  partner                     Partner?         @relation(fields: [partnerId], references: [id])
  employeeId                  String?
  employee                    Employee?        @relation(fields: [employeeId], references: [id])

  status                      CommissionStatus @default(PREDICTED)
  commissionType              CommissionType
  baseValue                   Decimal?         @db.Decimal(12, 2) // valor base de cálculo
  percentage                  Decimal?         @db.Decimal(8, 4)
  amount                      Decimal          @db.Decimal(12, 2) // valor final da comissão
  isFixed                     Boolean          @default(false)
  forecastReason              String?          // "3ª mensalidade paga"
  blockReason                 String?

  // Previsão de recebimento (ADENDO obrigatório)
  dateSaleBase                DateTime?        // data base da venda
  dateExpectedBilling         DateTime?        // previsão de faturamento
  dateExpectedCustomerPayment DateTime?        // previsão de pagamento do cliente
  dateExpectedRelease         DateTime?        // previsão de liberação da comissão
  avgReceiptDays              Int?             // prazo médio em dias
  expectedPaymentCompetence   String?          // "2026-10" competência de pagamento
  forecastStatus              String?          // "awaiting_billing" | "awaiting_payment" | "ready"

  releasedAt                  DateTime?
  paidAt                      DateTime?
  cancelledAt                 DateTime?
  cancelReason                String?

  notes                       String?
  createdAt                   DateTime         @default(now())
  updatedAt                   DateTime         @updatedAt

  paymentItems                PaymentItem[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, beneficiaryId])
  @@index([tenantId, saleId])
  @@index([tenantId, sellerId])
  @@index([tenantId, expectedPaymentCompetence])
  @@map("commissions")
}

enum CommissionStatus {
  PREDICTED
  BLOCKED
  RELEASED
  PAID
  CANCELLED
  REVERSED
}

// ─── PAYMENTS ─────────────────────────────────────────────────────────────────

model PaymentBatch {
  id           String            @id @default(cuid())
  tenantId     String
  tenant       Tenant            @relation(fields: [tenantId], references: [id])
  competence   String            // "2026-06"
  status       PaymentBatchStatus @default(OPEN)
  totalGross   Decimal           @db.Decimal(12, 2) @default(0)
  totalNet     Decimal           @db.Decimal(12, 2) @default(0)
  notes        String?
  createdById  String?
  approvedById String?
  approvedAt   DateTime?
  paidAt       DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  items        PaymentItem[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("payment_batches")
}

enum PaymentBatchStatus {
  OPEN
  PENDING_APPROVAL
  APPROVED
  PAID
  CANCELLED
}

model PaymentItem {
  id               String       @id @default(cuid())
  batchId          String
  batch            PaymentBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  commissionId     String
  commission       Commission   @relation(fields: [commissionId], references: [id])
  beneficiaryType  BeneficiaryType
  beneficiaryId    String
  beneficiaryName  String?
  grossValue       Decimal      @db.Decimal(12, 2)
  discounts        Decimal      @db.Decimal(12, 2) @default(0)
  netValue         Decimal      @db.Decimal(12, 2)
  paymentMethod    String?      @default("pix")
  pixKey           String?
  receiptUrl       String?
  status           String       @default("pending")
  notes            String?
  createdAt        DateTime     @default(now())

  @@index([batchId])
  @@index([commissionId])
  @@map("payment_items")
}

// ─── GOALS ────────────────────────────────────────────────────────────────────

model Goal {
  id              String   @id @default(cuid())
  tenantId        String
  sellerId        String?
  seller          Seller?  @relation(fields: [sellerId], references: [id])
  teamName        String?
  month           String   // "2026-06"
  type            String   @default("revenue") // revenue | sales_count | mrr | implantation | mix
  targetValue     Decimal  @db.Decimal(12, 2)
  achievedValue   Decimal  @db.Decimal(12, 2) @default(0)
  bonusAmount     Decimal? @db.Decimal(12, 2)
  bonusPercentage Decimal? @db.Decimal(8, 4)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, sellerId, month])
  @@map("goals")
}

// ─── CAMPAIGNS ────────────────────────────────────────────────────────────────

model Campaign {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  name        String
  description String?
  type        String   // product_mix | no_discount | annual_contract | ranking
  startDate   DateTime
  endDate     DateTime
  rules       Json     // configuração flexível da campanha
  bonusAmount Decimal? @db.Decimal(12, 2)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, active])
  @@map("campaigns")
}

// ─── AUDIT ────────────────────────────────────────────────────────────────────

model AuditLog {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  userId       String?
  user         User?    @relation(fields: [userId], references: [id])
  action       String   // CREATE | UPDATE | DELETE | STATUS_CHANGE | LOGIN
  entity       String   // "commission" | "sale" | "payment_batch"
  entityId     String?
  previousData Json?
  newData      Json?
  ipAddress    String?
  userAgent    String?
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, entity, entityId])
  @@index([tenantId, userId])
  @@index([createdAt])
  @@map("audit_logs")
}
