// Comissiona AI — Prisma Schema
// Multi-tenant SaaS para gestão de comissões comerciais

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  document    String?
  email       String
  phone       String?
  logoUrl     String?
  taxRate     Decimal  @default(0.00) @db.Decimal(5, 4)
  plan        String   @default("starter")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users            User[]
  products         Product[]
  commissionRules  CommissionRule[]
  sellers          Seller[]
  partners         Partner[]
  employees        Employee[]
  customers        Customer[]
  sales            Sale[]
  commissions      Commission[]
  paymentBatches   PaymentBatch[]
  goals            Goal[]
  campaigns        Campaign[]
  auditLogs        AuditLog[]

  @@index([slug])
  @@map("tenants")
}

model User {
  id           String    @id @default(cuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id])
  name         String
  email        String
  passwordHash String
  role         UserRole  @default(SELLER)
  active       Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  sellerId     String?   @unique
  partnerId    String?   @unique
  employeeId   String?   @unique
  seller       Seller?   @relation(fields: [sellerId], references: [id])
  partner      Partner?  @relation(fields: [partnerId], references: [id])
  employee     Employee? @relation(fields: [employeeId], references: [id])
  auditLogs    AuditLog[]
  refreshTokens RefreshToken[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

enum UserRole {
  ADMIN
  SALES_MANAGER
  FINANCIAL
  SELLER
  PARTNER
  EMPLOYEE
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

model Product {
  id                  String      @id @default(cuid())
  tenantId            String
  tenant              Tenant      @relation(fields: [tenantId], references: [id])
  name                String
  description         String?
  category            String?
  type                ProductType @default(MAIN)
  parentId            String?
  parent              Product?    @relation("ProductModules", fields: [parentId], references: [id])
  modules             Product[]   @relation("ProductModules")
  color               String?     @default("#4f46e5")
  hasImplantation     Boolean     @default(false)
  hasMonthly          Boolean     @default(true)
  allowsUpsell        Boolean     @default(false)
  allowsCrossSell     Boolean     @default(false)
  generatesCommission Boolean     @default(true)
  active              Boolean     @default(true)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  commissionRules     CommissionRule[]
  saleItems           SaleItem[]
  goals               Goal[]

  @@index([tenantId])
  @@index([tenantId, active])
  @@map("products")
}

enum ProductType {
  MAIN
  MODULE
  ADDON
  SERVICE
  PARTNER_PRODUCT
}

model CommissionRule {
  id                      String          @id @default(cuid())
  tenantId                String
  tenant                  Tenant          @relation(fields: [tenantId], references: [id])
  name                    String
  description             String?
  productId               String?
  product                 Product?        @relation(fields: [productId], references: [id])
  productCategory         String?
  saleOrigin              String?
  beneficiaryType         BeneficiaryType
  commissionType          CommissionType
  percentage              Decimal?        @db.Decimal(8, 4)
  fixedAmount             Decimal?        @db.Decimal(12, 2)
  triggerEvent            TriggerEvent    @default(INVOICE_PAID)
  installmentNumber       Int?
  appliesAfterDays        Int?
  appliesOnNetAmount      Boolean         @default(true)
  requiresCustomerActive  Boolean         @default(true)
  requiresInvoicePaid     Boolean         @default(true)
  requiresManagerApproval Boolean         @default(false)
  active                  Boolean         @default(true)
  startDate               DateTime?
  endDate                 DateTime?
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt
  commissions             Commission[]

  @@index([tenantId])
  @@index([tenantId, productId])
  @@index([tenantId, active])
  @@map("commission_rules")
}

enum BeneficiaryType {
  SELLER
  PARTNER
  EMPLOYEE
}

enum CommissionType {
  PERCENTAGE_IMPLANTATION
  PERCENTAGE_MONTHLY
  FIXED_AMOUNT
  FIRST_MONTHLY_PAYMENT
  THIRD_MONTHLY_PAYMENT
  RECURRING
  BONUS
}

enum TriggerEvent {
  CONTRACT_SIGNED
  INVOICE_ISSUED
  INVOICE_PAID
  FIRST_INVOICE_PAID
  THIRD_INVOICE_PAID
  MANUAL_APPROVAL
}

model Seller {
  id        String    @id @default(cuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  name      String
  email     String
  phone     String?
  role      String?
  team      String?
  managerId String?
  manager   Seller?   @relation("SellerManager", fields: [managerId], references: [id])
  reports   Seller[]  @relation("SellerManager")
  status    String    @default("active")
  joinDate  DateTime?
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user        User?
  sales       Sale[]
  commissions Commission[]
  goals       Goal[]
  customers   Customer[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("sellers")
}

model Partner {
  id                 String   @id @default(cuid())
  tenantId           String
  tenant             Tenant   @relation(fields: [tenantId], references: [id])
  name               String
  type               String   @default("pf")
  document           String?
  email              String
  phone              String?
  pixKey             String?
  bankName           String?
  bankAgency         String?
  bankAccount        String?
  authorizedProducts String[]
  status             String   @default("active")
  active             Boolean  @default(true)
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user        User?
  sales       Sale[]
  commissions Commission[]
  customers   Customer[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("partners")
}

model Employee {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  name       String
  email      String
  department String?
  status     String   @default("active")
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user        User?
  sales       Sale[]       @relation("EmployeeReferrals")
  commissions Commission[]
  customers   Customer[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("employees")
}

model Customer {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  companyName String
  tradeName   String?
  document    String?
  segment     String?
  city        String?
  state       String?
  email       String?
  phone       String?
  status      String    @default("active")
  origin      String?
  sellerId    String?
  seller      Seller?   @relation(fields: [sellerId], references: [id])
  partnerId   String?
  partner     Partner?  @relation(fields: [partnerId], references: [id])
  employeeId  String?
  employee    Employee? @relation(fields: [employeeId], references: [id])
  entryDate   DateTime?
  notes       String?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  sales       Sale[]

  @@index([tenantId])
  @@index([tenantId, sellerId])
  @@map("customers")
}

model Sale {
  id               String     @id @default(cuid())
  tenantId         String
  tenant           Tenant     @relation(fields: [tenantId], references: [id])
  customerId       String
  customer         Customer   @relation(fields: [customerId], references: [id])
  sellerId         String
  seller           Seller     @relation(fields: [sellerId], references: [id])
  partnerId        String?
  partner          Partner?   @relation(fields: [partnerId], references: [id])
  employeeId       String?
  employee         Employee?  @relation("EmployeeReferrals", fields: [employeeId], references: [id])
  origin           String
  status           SaleStatus @default(PROPOSAL)
  taxRate          Decimal    @db.Decimal(5, 4)
  saleDate         DateTime
  contractDate     DateTime?
  billingStartDate DateTime?
  cancelledAt      DateTime?
  cancelReason     String?
  notes            String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  items       SaleItem[]
  commissions Commission[]
  invoices    Invoice[]

  @@index([tenantId])
  @@index([tenantId, sellerId])
  @@index([tenantId, status])
  @@index([tenantId, saleDate])
  @@map("sales")
}

enum SaleStatus {
  PROPOSAL
  CLOSED
  CONTRACT_SIGNED
  IN_IMPLEMENTATION
  ACTIVE
  CANCELLED
  DEFAULTING
  SUSPENDED
}

model SaleItem {
  id         String   @id @default(cuid())
  saleId     String
  sale       Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  type       ItemType @default(MONTHLY)
  grossValue Decimal  @db.Decimal(12, 2)
  netValue   Decimal  @db.Decimal(12, 2)
  taxRate    Decimal  @db.Decimal(5, 4)
  quantity   Int      @default(1)
  notes      String?
  createdAt  DateTime @default(now())
  commissions Commission[]

  @@index([saleId])
  @@index([productId])
  @@map("sale_items")
}

enum ItemType {
  IMPLANTATION
  MONTHLY
  ANNUAL
  ONE_TIME
}

model Invoice {
  id             String        @id @default(cuid())
  tenantId       String
  saleId         String
  sale           Sale          @relation(fields: [saleId], references: [id])
  installmentNum Int
  dueDate        DateTime
  amount         Decimal       @db.Decimal(12, 2)
  status         InvoiceStatus @default(PENDING)
  paidAt         DateTime?
  paidAmount     Decimal?      @db.Decimal(12, 2)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([tenantId])
  @@index([saleId])
  @@index([tenantId, status])
  @@map("invoices")
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

model Commission {
  id                          String           @id @default(cuid())
  tenantId                    String
  tenant                      Tenant           @relation(fields: [tenantId], references: [id])
  saleId                      String
  sale                        Sale             @relation(fields: [saleId], references: [id])
  saleItemId                  String?
  saleItem                    SaleItem?        @relation(fields: [saleItemId], references: [id])
  ruleId                      String
  rule                        CommissionRule   @relation(fields: [ruleId], references: [id])
  beneficiaryType             BeneficiaryType
  beneficiaryId               String
  sellerId                    String?
  seller                      Seller?          @relation(fields: [sellerId], references: [id])
  partnerId                   String?
  partner                     Partner?         @relation(fields: [partnerId], references: [id])
  employeeId                  String?
  employee                    Employee?        @relation(fields: [employeeId], references: [id])
  status                      CommissionStatus @default(PREDICTED)
  commissionType              CommissionType
  baseValue                   Decimal?         @db.Decimal(12, 2)
  percentage                  Decimal?         @db.Decimal(8, 4)
  amount                      Decimal          @db.Decimal(12, 2)
  isFixed                     Boolean          @default(false)
  forecastReason              String?
  blockReason                 String?
  dateSaleBase                DateTime?
  dateExpectedBilling         DateTime?
  dateExpectedCustomerPayment DateTime?
  dateExpectedRelease         DateTime?
  avgReceiptDays              Int?
  expectedPaymentCompetence   String?
  forecastStatus              String?
  releasedAt                  DateTime?
  paidAt                      DateTime?
  cancelledAt                 DateTime?
  cancelReason                String?
  notes                       String?
  createdAt                   DateTime         @default(now())
  updatedAt                   DateTime         @updatedAt
  paymentItems                PaymentItem[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, beneficiaryId])
  @@index([tenantId, saleId])
  @@index([tenantId, sellerId])
  @@index([tenantId, expectedPaymentCompetence])
  @@map("commissions")
}

enum CommissionStatus {
  PREDICTED
  BLOCKED
  RELEASED
  PAID
  CANCELLED
  REVERSED
}

model PaymentBatch {
  id           String             @id @default(cuid())
  tenantId     String
  tenant       Tenant             @relation(fields: [tenantId], references: [id])
  competence   String
  status       PaymentBatchStatus @default(OPEN)
  totalGross   Decimal            @db.Decimal(12, 2) @default(0)
  totalNet     Decimal            @db.Decimal(12, 2) @default(0)
  notes        String?
  createdById  String?
  approvedById String?
  approvedAt   DateTime?
  paidAt       DateTime?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  items        PaymentItem[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("payment_batches")
}

enum PaymentBatchStatus {
  OPEN
  PENDING_APPROVAL
  APPROVED
  PAID
  CANCELLED
}

model PaymentItem {
  id              String          @id @default(cuid())
  batchId         String
  batch           PaymentBatch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  commissionId    String
  commission      Commission      @relation(fields: [commissionId], references: [id])
  beneficiaryType BeneficiaryType
  beneficiaryId   String
  beneficiaryName String?
  grossValue      Decimal         @db.Decimal(12, 2)
  discounts       Decimal         @db.Decimal(12, 2) @default(0)
  netValue        Decimal         @db.Decimal(12, 2)
  paymentMethod   String?         @default("pix")
  pixKey          String?
  receiptUrl      String?
  status          String          @default("pending")
  notes           String?
  createdAt       DateTime        @default(now())

  @@index([batchId])
  @@index([commissionId])
  @@map("payment_items")
}


model Campaign {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  name        String
  description String?
  type        String
  startDate   DateTime
  endDate     DateTime
  rules       Json
  bonusAmount Decimal? @db.Decimal(12, 2)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, active])
  @@map("campaigns")
}

model AuditLog {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  userId       String?
  user         User?    @relation(fields: [userId], references: [id])
  action       String
  entity       String
  entityId     String?
  previousData Json?
  newData      Json?
  ipAddress    String?
  userAgent    String?
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, entity, entityId])
  @@index([tenantId, userId])
  @@index([createdAt])
  @@map("audit_logs")
}
model Goal {
  id              String    @id @default(cuid())
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id])
  productId       String?
  product         Product?  @relation(fields: [productId], references: [id])
  sellerId        String?
  seller          Seller?   @relation(fields: [sellerId], references: [id])
  teamName        String?
  periodType      String    @default("monthly")
  periodKey       String    @default("")
  month           String?
  type            String    @default("revenue")
  targetValue     Decimal   @db.Decimal(12, 2)
  achievedValue   Decimal   @db.Decimal(12, 2) @default(0)
  bonusAmount     Decimal?  @db.Decimal(12, 2)
  bonusPercentage Decimal?  @db.Decimal(8, 4)
  // Validade: opcional. Se preenchida, a meta só conta como vigente dentro
  // dessa janela de datas. Usado junto com "active" para permitir manter
  // metas antigas no histórico sem elas contarem no acompanhamento atual.
  startDate       DateTime?
  endDate         DateTime?
  // Quando uma nova meta é criada para o mesmo produto/vendedor/período,
  // a(s) meta(s) anterior(es) equivalentes são marcadas active=false
  // automaticamente, em vez de ficarem duplicadas.
  active          Boolean   @default(true)
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([tenantId])
  @@index([tenantId, sellerId, month])
  @@index([tenantId, productId, periodKey])
  @@index([tenantId, active])
  @@map("goals")
}
